{
  "name": "text-extractor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config web/vite.config.ts --port=3000 --host=0.0.0.0",
    "build": "vite build --config web/vite.config.ts",
    "preview": "vite preview --config web/vite.config.ts",
    "clean": "rm -rf dist",
    "debug": "bash scripts/debug.sh",
    "lint": "eslint . && npm run typecheck",
    "typecheck": "tsc --project web/tsconfig.json --noEmit && tsc --project gateway/tsconfig.json --noEmit && tsc --project edge/tsconfig.json --noEmit",
    "test": "node --import tsx --test web/src/**/*.test.ts gateway/src/**/*.test.ts",
    "test:ocr:browser": "node --import tsx --test web/src/**/*.ocr-test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "express": "^5.2.1",
    "lucide-react": "^0.546.0",
    "mime-types": "^3.0.2",
    "motion": "^12.23.24",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.2.3"
  }
}
