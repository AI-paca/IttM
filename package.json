{
  "name": "text-extractor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build --config web/vite.config.ts",
    "build:pages": "VITE_BASE_PATH=/IttM/ npm run build:web",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server.js",
    "build:server:standalone": "esbuild server.ts --bundle --platform=node --format=cjs --define:process.env.NODE_ENV='\"production\"' --log-override:empty-import-meta=silent --outfile=dist/server.cjs",
    "preview": "vite preview --config web/vite.config.ts",
    "clean": "rm -rf dist",
    "debug": "bash scripts/ci/debug.sh",
    "extract": "tsx scripts/cli/ittm-extract.ts",
    "lint": "eslint . && npm run typecheck",
    "typecheck": "tsc --project web/tsconfig.json --noEmit && tsc --project gateway/tsconfig.json --noEmit && tsc --project edge/tsconfig.json --noEmit",
    "test": "node --import tsx --test web/src/**/*.test.ts gateway/src/**/*.test.ts edge/**/*.test.ts",
    "test:contract": "bash scripts/ci/run-contract-tests.sh",
    "test:smoke": "bash scripts/ci/run-smoke-tests.sh",
    "test:sast": "bash scripts/ci/run-sast.sh",
    "test:sca": "bash scripts/ci/run-sca.sh",
    "test:pages": "node scripts/ci/verify-pages-build.mjs dist /IttM/",
    "test:engine-docs": "python3 scripts/ci/verify_engine_profile_docs.py && python3 scripts/ci/verify_pipeline_flag_docs.py",
    "test:pages:live": "node scripts/ci/smoke-pages.mjs",
    "test:compose": "bash scripts/ci/smoke-compose.sh",
    "test:resources": "bash scripts/ci/run-resource-tests.sh",
    "test:ocr:quality": "OCR_TEST_TIER=quality bash scripts/ci/run-resource-tests.sh",
    "test:ocr:browser": "node --import tsx --test web/src/**/*.ocr-test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "NODE_ENV=production node dist/server.js"
  },
  "dependencies": {
    "express": "^5.2.1",
    "mime-types": "^3.0.2",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.42.0",
    "pdfjs-dist": "^5.7.284",
    "prettier": "^3.8.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwindcss": "^4.1.14",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.2.3"
  }
}
